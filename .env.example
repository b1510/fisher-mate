# Neon Postgres — pooled connection (used at runtime by Prisma Client)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# Neon Postgres — direct connection (used only for `prisma migrate`)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# OpenAI API key — server-only, used by api/analyze.ts
OPENAI_API_KEY="sk-..."

# Vercel Blob — server-only, used by api/blob-upload-token.ts
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
